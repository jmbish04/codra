{
  "name": "codra",
  "version": "0.9.2",
  "description": "Open-source code review engine",
  "author": "Devarshi Shimpi",
  "license": "AGPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/devarshishimpi/codra.git"
  },
  "homepage": "https://codra.run",
  "bugs": {
    "url": "https://github.com/devarshishimpi/codra/issues"
  },
  "scripts": {
    "build": "vite build && npm run types",
    "types": "wrangler types ./src/server/worker-env.d.ts",
    "cf-typegen": "npm run types",
    "deploy": "npm run build && npm run migrate:remote && wrangler deploy",
    "dev": "concurrently -k -n CLIENT,WORKER -c cyan,green \"npm:dev:client\" \"npm:dev:worker\"",
    "dev:client": "vite build --watch --mode development",
    "dev:worker": "wrangler dev --local",
    "start": "npm run dev",
    "setup:cloudflare": "node scripts/setup-cloudflare.js",
    "db:generate": "drizzle-kit generate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "migrate:local": "drizzle-kit generate && wrangler d1 migrations apply codra --local",
    "migrate:remote": "drizzle-kit generate && wrangler d1 migrations apply codra --remote",
    "migrate": "npm run migrate:remote",
    "queues:create": "node scripts/createQueues.mjs",
    "test": "node scripts/test.mjs",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.43.1",
    "@cloudflare/vitest-pool-workers": "^0.14.3",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/picomatch": "^4.0.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/browser": "^4.1.4",
    "@vitest/browser-playwright": "^4.1.4",
    "chalk": "^5.6.2",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.10",
    "jsdom": "^29.0.2",
    "ora": "^9.4.0",
    "playwright": "^1.59.1",
    "prompts": "^2.4.2",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4",
    "wrangler": "^4.81.1"
  },
  "dependencies": {
    "@cloudflare/ai-chat": "^0.9.3",
    "@cloudflare/codemode": "^0.4.2",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-progress": "^1.1.12",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@udecode/plate": "^48.0.5",
    "@udecode/plate-basic-marks": "^48.0.0",
    "@udecode/plate-block-quote": "^48.0.0",
    "@udecode/plate-code-block": "^48.0.0",
    "@udecode/plate-common": "^41.0.13",
    "@udecode/plate-heading": "^48.0.0",
    "@udecode/plate-list": "^48.0.0",
    "@udecode/plate-markdown": "^48.0.2",
    "agents": "^0.17.3",
    "ai": "^7.0.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "drizzle-zod": "^0.8.3",
    "hono": "^4.12.12",
    "jsonrepair": "^3.13.3",
    "lucide-react": "^1.8.0",
    "picomatch": "^4.0.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-is": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.14.0",
    "recharts": "^3.8.1",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "slate": "^0.126.0",
    "slate-dom": "^0.126.0",
    "slate-history": "^0.113.1",
    "slate-react": "^0.126.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "workers-ai-provider": "^3.3.1",
    "zod": "^4.3.6"
  }
}
